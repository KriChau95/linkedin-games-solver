{
  "manifest_version": 3,
  "name": "LinkedIn Game Solver",
  "version": "0.1",
  "description": "TS boilerplate for Chrome extension",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "64": "logo.png",
      "128": "logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["dist/popup.js"]
    }
  ],
  "web_accessible_resources": [{
    "resources": ["emulate-tab.min.js"],
    "matches": ["*://*.linkedin.com/*"]
  }]
}
